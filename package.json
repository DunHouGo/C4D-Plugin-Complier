{
  "name": "c4d-plugin-compiler",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Boghma",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp exec tsc --noEmit && vp build",
    "preview": "vp preview",
    "typecheck": "vp exec tsc --noEmit",
    "lint": "vp lint . --max-warnings 0",
    "lint:fix": "vp lint . --fix",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "test": "vp exec vitest",
    "test:run": "vp exec vitest run",
    "test:ui": "vp exec vitest --ui",
    "test:coverage": "vp exec vitest run --coverage",
    "rust:fmt": "cd src-tauri && cargo fmt",
    "rust:fmt:check": "cd src-tauri && cargo fmt --check",
    "rust:clippy": "cd src-tauri && cargo clippy -- -D warnings",
    "rust:clippy:fix": "cd src-tauri && cargo clippy --fix --allow-dirty",
    "rust:test": "cd src-tauri && cargo test",
    "rust:bindings": "cd src-tauri && cargo test export_bindings -- --ignored --nocapture",
    "tauri": "tauri",
    "tauri:dev": "vpr tauri dev",
    "tauri:build": "vpr tauri build",
    "tauri:check": "vp exec tsc --noEmit && vpr tauri build --check",
    "test:all": "vpr test:run && vpr rust:test",
    "check:all": "vp check && vpr rust:fmt:check && vpr rust:clippy && vpr test:run && vpr rust:test",
    "fix:all": "vpr lint:fix && vpr format && vpr rust:fmt && vpr rust:clippy:fix",
    "build:analyze": "vp build && echo '\\nBundle analysis complete. Check dist/ folder sizes or use a tool like webpack-bundle-analyzer on the dist folder.'",
    "release:prepare": "vp exec node scripts/prepare-release.js",
    "task:complete": "vp exec node scripts/complete-task.js",
    "task:rename-done": "vp exec node scripts/complete-task.js --rename-existing"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tauri-apps/api": "2.9.1",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-dialog": "2.4.2",
    "@tauri-apps/plugin-fs": "2.4.4",
    "@tauri-apps/plugin-log": "2.7.1",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "2.5.2",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.9.0",
    "@tauri-apps/plugin-window-state": "2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^25.7.3",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.0",
    "react-resizable-panels": "^3.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.9.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "jsdom": "^27.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plus": "^0.1.20",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.13.0",
  "copyright": "Copyright 2026 Boghma. All rights reserved."
}
